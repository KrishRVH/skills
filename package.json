{
  "name": "skills-markdown",
  "private": true,
  "scripts": {
    "format": "prettier \"**/*.md\" --write",
    "format:check": "prettier \"**/*.md\" --check",
    "lint": "markdownlint-cli2",
    "lint:fix": "markdownlint-cli2 --fix",
    "skills:check": "bun .config/skills/validate.mjs",
    "skills:test": "bun test \"$PWD/.config/skills/validate.test.mjs\"",
    "standards": "bun run format && bun run lint:fix",
    "standards:check": "bun run lint && bun run format:check"
  },
  "devDependencies": {
    "entities": "^4.5.0",
    "js-yaml": "^5.2.1",
    "jsonc-parser": "^3.3.1",
    "markdown-it": "^14.3.0",
    "markdownlint-cli2": "^0.23.1",
    "prettier": "^3.9.6"
  }
}
